DISCORD_TOKEN=
COMMAND_PREFIX=!
# Point at the Laravel backend, including the /api/v1 prefix.
BACKEND_URL=http://127.0.0.1:8000/api/v1
# Set to "false" to call the real backend, "true" (or unset) to use mock data.
USE_MOCK_DATA=true
GROQ_API_KEY=
GROQ_MODEL=

# --- Proactive alerts (optional) ---
# Channel the bot posts new alerts into. Leave blank to disable proactive alerts.
DISCORD_CHANNEL_ID=
# How often (ms) to poll GET /alerts for new alerts. Default 20000.
ALERT_POLL_MS=20000
# "true" also posts alerts that already exist when the bot starts.
# Default (false) silently seeds them so the channel isn't flooded on boot.
ALERT_ANNOUNCE_EXISTING=false
